          script.
            (function(){
              var tableContainer = document.querySelector('.table-responsive');
              if(!tableContainer) return;

              var btnX = document.getElementById('scroll-btn-x');
              var btnY = document.getElementById('scroll-btn-y');

              function getBoundsX() {
                var sidebar = document.getElementById('sidebar');
                var w = (sidebar && window.innerWidth > 991) ? sidebar.offsetWidth : 0;
                return { min: w + 20, max: window.innerWidth - 70 }; // 70px (width 50 + pad 20)
              }
              function getBoundsY() {
                return { min: 120, max: window.innerHeight - 70 };
              }

              function updateButtonPositions() {
                if (isDraggingX || isDraggingY) return;
                var bX = getBoundsX();
                var bY = getBoundsY();

                var maxScrollX = tableContainer.scrollWidth - tableContainer.clientWidth;
                if (maxScrollX > 0) {
                  btnX.style.display = 'flex';
                  var percentX = tableContainer.scrollLeft / maxScrollX;
                  btnX.style.left = (bX.min + percentX * (bX.max - bX.min)) + 'px';
                } else {
                  btnX.style.display = 'none';
                }

                var maxScrollY = tableContainer.scrollHeight - tableContainer.clientHeight;
                if (maxScrollY > 0) {
                  btnY.style.display = 'flex';
                  var percentY = tableContainer.scrollTop / maxScrollY;
                  btnY.style.top = (bY.min + percentY * (bY.max - bY.min)) + 'px';
                } else {
                  btnY.style.display = 'none';
                }
              }

              tableContainer.addEventListener('scroll', updateButtonPositions);
              window.addEventListener('resize', updateButtonPositions);
              
              var observer = new MutationObserver(function(){ setTimeout(updateButtonPositions, 100); });
              observer.observe(tableContainer, { childList: true, subtree: true });
              setTimeout(updateButtonPositions, 500);

              // Hover
              if(btnX){
                btnX.addEventListener('mouseenter', function(){ btnX.style.backgroundColor = 'rgba(0,200,83,0.95)'; });
                btnX.addEventListener('mouseleave', function(){ btnX.style.backgroundColor = 'rgba(0,200,83,0.6)'; });
              }
              if(btnY){
                btnY.addEventListener('mouseenter', function(){ btnY.style.backgroundColor = 'rgba(0,123,255,0.95)'; });
                btnY.addEventListener('mouseleave', function(){ btnY.style.backgroundColor = 'rgba(0,123,255,0.6)'; });
              }

              // Drag X
              var isDraggingX = false, startMouseX = 0, startLeft = 0;
              if(btnX){
                btnX.addEventListener('mousedown', function(e){
                  isDraggingX = true;
                  startMouseX = e.clientX;
                  startLeft = parseFloat(btnX.style.left) || getBoundsX().min;
                  btnX.style.cursor = 'grabbing';
                  document.body.style.userSelect = 'none';
                  e.preventDefault();
                });
              }

              // Drag Y
              var isDraggingY = false, startMouseY = 0, startTop = 0;
              if(btnY){
                btnY.addEventListener('mousedown', function(e){
                  isDraggingY = true;
                  startMouseY = e.clientY;
                  startTop = parseFloat(btnY.style.top) || getBoundsY().min;
                  btnY.style.cursor = 'grabbing';
                  document.body.style.userSelect = 'none';
                  e.preventDefault();
                });
              }

              document.addEventListener('mousemove', function(e){
                if(isDraggingX){
                  var dx = e.clientX - startMouseX;
                  var bX = getBoundsX();
                  var newLeft = Math.max(bX.min, Math.min(bX.max, startLeft + dx));
                  btnX.style.left = newLeft + 'px';
                  var percentX = (newLeft - bX.min) / (bX.max - bX.min);
                  var maxScrollX = tableContainer.scrollWidth - tableContainer.clientWidth;
                  tableContainer.scrollLeft = percentX * maxScrollX;
                }
                if(isDraggingY){
                  var dy = e.clientY - startMouseY;
                  var bY = getBoundsY();
                  var newTop = Math.max(bY.min, Math.min(bY.max, startTop + dy));
                  btnY.style.top = newTop + 'px';
                  var percentY = (newTop - bY.min) / (bY.max - bY.min);
                  var maxScrollY = tableContainer.scrollHeight - tableContainer.clientHeight;
                  tableContainer.scrollTop = percentY * maxScrollY;
                }
              });

              document.addEventListener('mouseup', function(){
                if(isDraggingX) { isDraggingX = false; btnX.style.cursor = 'grab'; document.body.style.userSelect = ''; }
                if(isDraggingY) { isDraggingY = false; btnY.style.cursor = 'grab'; document.body.style.userSelect = ''; }
              });

            })();