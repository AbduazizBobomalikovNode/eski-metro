                            th  Xodim 
                            th  Ma'lumot manbai
                            th  Status 
                            th  Ammallar 
                        tbody
                          - for (var x = 0; x < docs.length; x++)
                            tr(style=(docs[x].real === false ? 'background-color: rgba(255,152,0,0.15);' : ''))
                              td
                                .form-check.form-check-muted.m-0
                                  label.form-check-label
                                    input(id=docs[x].id,onclick='chekbox()').form-check-input(type='checkbox')
                              td  #{docs[x].son}
                              td  #{docs[x].id}
                              td  #{doc_name[docs[x].type]}
                              td  #{lang[docs[x].lang]} 
                              td  #{docs[x].comply_with} 
                              td  #{docs[x].compare} 
                              td  #{docs[x].organization?docs[x].organization.length>25?docs[x].organization.slice(0,25):docs[x].organization:""} 
                              td  #{docs[x].date}
                              td  #{docs[x].employee}
                              if docs[x].restore_date
                                td(style='color: #e67e22; font-weight: 500;')
                                  i.mdi.mdi-restore(style='margin-right:3px;')
                                  | qayta tiklangan #{docs[x].restore_date}
                              else
                                td(style='color: #27ae60;')
                                  i.mdi.mdi-check-circle(style='margin-right:3px;')
                                  | tizimni o'zida yaratilgan
                              if !activeDocumentUpdate
                                td  #{docs[x].status?"Tasdiqlangan":"Tasdiqlanmagan"}
                              else 
                                if !docs[x].status
                                  td
                                    a(href = "/certifcate/active/"+docs[x].id)
                                      button.btn.btn-success.btn-icon-text(type='button')
                                        i.mdi.mdi-check-circle
                                        span   Tasdiqlash
                                else
                                  td Tasdiqlangan
                              td
                                .btn-group(role='group' aria-label='Basic example')
                                  if view 
                                    a(href = docs[x].link)
                                      button.btn.btn-outline-primary(type='button')
                                        i.mdi.mdi-eye
                                  if update && docs[x].status && activeDocumentUpdate 
                                    a(href='/certifcate/update/'+docs[x].id)
                                      button.btn.btn-outline-light(type='button' title='tahrirlash')
                                        i.mdi.mdi-lead-pencil
                                  else if update && !docs[x].status
                                    a(href='/certifcate/update/'+docs[x].id)
                                      button.btn.btn-outline-light(type='button' title='tahrirlash')
                                        i.mdi.mdi-lead-pencil
                                  if deletes && docs[x].status &&  activeDocumentDelete
                                      a(href='/certifcate/delete/'+docs[x].id)
                                        button.btn.btn-outline-danger(type='button')
                                          i.mdi.mdi-close
                                  else if deletes && !docs[x].status
